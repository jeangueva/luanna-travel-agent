# Server
PORT=8000
ENVIRONMENT=development

# WhatsApp Provider (meta | whapi)
WHATSAPP_PROVIDER=meta

# Meta Cloud API (Official WhatsApp)
# Get these from: https://developers.facebook.com/docs/whatsapp/cloud-api
META_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxx
META_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxx
META_WEBHOOK_VERIFY_TOKEN=your_verify_token
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API (Get from https://console.anthropic.com/account/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Travelpayouts (Register at https://support.travelpayouts.com)
TRAVELPAYOUTS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRAVELPAYOUTS_MARKER=xxxxxxxx

# Database
DATABASE_URL=sqlite:///./luanna.db
